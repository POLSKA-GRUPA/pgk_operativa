# ===================================================================
# pgk_operativa - Plantilla de configuracion por maquina
# ===================================================================
# Copia este archivo a .env y rellena los valores reales.
# NUNCA commitear .env. Los secretos se gestionan fuera del repo.
# ===================================================================

# ===== RUTAS DE USUARIO (ajustar por maquina) =====
# Estas rutas varian por empleado. El codigo del repo las usa solo
# via variables de entorno, nunca hardcoded.
PGK_USER_HOME=/home/usuario
PGK_LOCAL_DOCUMENTS_PATH=/home/usuario/Documents/PGK
PGK_GOOGLE_CREDENTIALS_PATH=/home/usuario/.config/pgk/google_credentials.json

# ===== POSTGRES REMOTO (via tunel SSH) =====
# El tunel se levanta desde el CLI con sshtunnel.
PGK_DB_HOST=127.0.0.1
PGK_DB_PORT=5432
PGK_DB_NAME=pgk_database
PGK_DB_SCHEMA=pgk_admin
PGK_DB_USER=dev_devin
PGK_DB_PASSWORD=
# Tunel SSH
PGK_SSH_HOST=209.74.72.83
PGK_SSH_PORT=22
PGK_SSH_USER=
PGK_SSH_KEY_PATH=~/.ssh/id_rsa

# ===== Z.AI (default primario) =====
# Z.ai provee dos endpoints con la misma API key:
#   a) OpenAI-compatible: Z.ai coding plan (GLM-4.6)
#   b) Anthropic-compatible: proxy para Claude SDK
ZAI_API_KEY=
# OpenAI SDK apuntando a Z.ai coding plan
ZAI_OPENAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_OPENAI_MODEL=glm-4.6
# Anthropic SDK apuntando a Z.ai proxy
ZAI_ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# ===== PROVEEDORES PARA CONSENSO OPT-IN =====
# Solo se consultan cuando el empleado invoca /consenso explicitamente.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

XAI_API_KEY=
XAI_MODEL=grok-3

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ===== PERPLEXITY (verificacion normativa) =====
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro

# ===== EMBEDDINGS =====
OPENAI_EMBEDDING_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ===== EMAIL PGK (solo borradores) =====
# Dominio 1: pgkhiszpania.com
EMAIL_IMAP_HOST=mail.pgkhiszpania.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=mail.pgkhiszpania.com
EMAIL_SMTP_PORT=465
EMAIL_USE_SSL=true

EMAIL_INFO_USER=info@pgkhiszpania.com
EMAIL_INFO_PASSWORD=
EMAIL_ADMIN_USER=admin@pgkhiszpania.com
EMAIL_ADMIN_PASSWORD=
EMAIL_KLIENT_USER=klient@pgkhiszpania.com
EMAIL_KLIENT_PASSWORD=
EMAIL_CONTABILIDAD_USER=contabilidad@pgkhiszpania.com
EMAIL_CONTABILIDAD_PASSWORD=

# Dominio 2: bizneswhiszpanii.com
EMAIL_BIZNES_IMAP_HOST=mail.bizneswhiszpanii.com
EMAIL_BIZNES_USER=info@bizneswhiszpanii.com
EMAIL_BIZNES_PASSWORD=

# ===== NOTION (opcional, fuente de verdad de casos de cliente) =====
NOTION_API_KEY=
NOTION_DB_CLIENTES=
NOTION_DB_EXPEDIENTES=
NOTION_DB_TAREAS=
NOTION_DB_DOCUMENTOS=
NOTION_DB_EMAILS=
NOTION_DB_PLANTILLAS=
NOTION_DB_CONFIG=

# ===== GOOGLE DRIVE (opcional) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DRIVE_FOLDER_ID=

# ===== Vertex / Google Cloud (opcional) =====
GOOGLE_CLOUD_PROJECT=
VERTEX_AI_LOCATION=us-central1

# ===== Runtime =====
PGK_ENVIRONMENT=development
PGK_LOG_LEVEL=INFO
PGK_CONSENSO_DEFAULT=false
